{
  "name": "shopping-list",
  "version": "4.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "varlock run -- next dev -p 3000",
    "dev:lan": "varlock run -- next dev -H 0.0.0.0 -p 3000",
    "build": "next build",
    "start": "varlock run -- next start",
    "db:generate": "varlock run -- drizzle-kit generate",
    "db:migrate": "varlock run -- drizzle-kit migrate",
    "lint": "oxlint .",
    "typecheck": "tsc --noEmit",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "prepare": "husky"
  },
  "dependencies": {
    "@base-ui/react": "^1.6.0",
    "@better-auth/drizzle-adapter": "^1.6.20",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/modifiers": "^9.0.0",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@hookform/resolvers": "^5.4.0",
    "@neondatabase/serverless": "^1.1.0",
    "better-auth": "^1.6.20",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.2",
    "lucide-react": "^1.23.0",
    "next": "^16.2.9",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-hook-form": "^7.80.0",
    "zod": "^4.4.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@varlock/keepass-plugin": "^1.0.0",
    "drizzle-kit": "^0.31.10",
    "husky": "^9.1.7",
    "oxfmt": "^0.56.0",
    "oxlint": "^1.71.0",
    "typescript": "^6.0.3",
    "varlock": "^1.7.2"
  },
  "engines": {
    "node": ">=22.13",
    "pnpm": ">=11"
  },
  "packageManager": "pnpm@11.8.0"
}
